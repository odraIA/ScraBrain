HF_TOKEN=
WANDB_API_KEY=
WANDB_MODE=offline

DATASETS_DIR=./datasets
EEG_DATASETS_DIR=./datasets
CHECKPOINTS_DIR=./checkpoints

CRISS_CROSS_CHECKPOINT=./checkpoints/baseline/meg-xl-med.ckpt
BIOCODEC_CHECKPOINT=./brainstorm/neuro_tokenizers/biocodec_ckpt.pt
BRAINOMNI_CHECKPOINT=./brainstorm/neuro_tokenizers/base/BrainOmni.pt
BRAINOMNI_BASE_CHECKPOINT=./brainstorm/neuro_tokenizers/base/BrainOmni.pt
BRAINOMNI_TINY_CHECKPOINT=./brainstorm/neuro_tokenizers/tiny/BrainOmni.pt
BRAINTOKENIZER_CHECKPOINT=./brainstorm/neuro_tokenizers/braintokenizer/BrainTokenizer.pt

ARMENI_ROOT=./datasets/armeni
GWILLIAMS_ROOT=./datasets/gwilliams
LIBRIBRAIN_ROOT=./datasets/libribrain
ZUCO_ROOT=./datasets/zuco2/data/zuco2
ZUCO_EEG_SENSOR_TYPE=eeg
EEG_READING_ROOTS=/workspace/datasets/zuco2/data/zuco2,/workspace/datasets/eegdash/data/nm000228
EEG_LISTENING_ROOTS=/workspace/datasets/OpenNeuroEEG_ds004408,/workspace/datasets/OpenNeuroEEG_ds007808

SHM_SIZE=64gb
OMP_NUM_THREADS=8
EEG_PREPROCESS_OMP_THREADS=4
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

EEG_GPU=0
EVAL_GPU=0
ARMENI_GPU=0
GWILLIAMS_GPU=0
ZUCO_GPU=0
LINEAR_PROBE_GPU=1
EEG_GPU_COUNT=1

EEG_TARGET_SFREQ=50
EEG_TOKENIZER_NAME=biocodec
EEG_TRAIN_FROM_SCRATCH=false
EEG_USE_PROMOTED_CHECKPOINT=false
EEG_PROMOTED_CHECKPOINT=
EEG_SWEEP_FREQUENCIES=25,50,100,128,200,250
EEG_SELECTION_METRIC=balanced_top10_accuracy_retrieval250
EEG_SELECTION_MODE=max

MONITOR_PORT=8080
EEG_MONITOR_PORT=8082
DOCKER_SOCK=/var/run/docker.sock

# Optional credentials for dataset download scripts. Never commit real values.
OSF_TOKEN=
RDR_USERNAME=
RDR_PASSWORD=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
