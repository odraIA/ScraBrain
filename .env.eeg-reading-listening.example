# Host directory containing all five dataset roots.
EEG_DATASETS_DIR=./datasets

# GPU visibility and reservation.
EEG_GPU=0
EEG_GPU_COUNT=1

# Shared-memory size for PyTorch DataLoader workers.
SHM_SIZE=64gb
OMP_NUM_THREADS=8

# Optional online Weights & Biases logging.
WANDB_MODE=offline
WANDB_API_KEY=
HF_TOKEN=

# Optional checkpoint overrides.
CRISS_CROSS_CHECKPOINT=./checkpoints/baseline/meg-xl-med.ckpt
BIOCODEC_CHECKPOINT=./brainstorm/neuro_tokenizers/biocodec_ckpt.pt
